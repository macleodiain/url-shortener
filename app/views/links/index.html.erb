<h1>URL Shortener</h1>


<%= form_with model: Link.new do |form| %>
  <div class = "flex gap-5 items-center">
    <%= form.url_field :url, placeholder: "http://www.example.com", required: true, class: "rounded flex-grow" %>
    <%= form.button "Save", class: "px-3 py-2 bg-gray-100 rounded" %>
  </div>
<% end %>

<hr />
<p>Saved Links</p>


<%= render @links %>