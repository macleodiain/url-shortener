<%= form_with model: @link do |form|%>
  <div>
    <%= form.label :url %>
    <%= form.url_field :url %>
  </div>

  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>
  <div>
    <%= form.label :description %>
    <%= form.text_field :description %>
  </div>
  <div>
    <%= form.label :image %>
    <%= form.text_field :image %>
  </div>

  <%= form.submit %>
<% end %>